# --- Anthropic ---
ANTHROPIC_API_KEY=

# --- API do blog (NextAssist) ---
BLOG_API_URL=https://rr-infocell-api-91248386036.southamerica-east1.run.app
BLOG_AUTOR=NextAssist

# --- Indexação no Google e métricas (Search Console) ---
# Domínio público onde os posts ficam acessíveis (sem barra no fim).
SITE_BASE_URL=https://www.nextassist-app.com.br
# Propriedade no Search Console: prefixo de URL (com barra no fim) ou "sc-domain:dominio".
SEARCH_CONSOLE_SITE_URL=sc-domain:nextassist-app.com.br
# URL do sitemap (reenviado ao Google após cada publicação).
SITEMAP_URL=https://www.nextassist-app.com.br/sitemap.xml
# Obs: reutiliza a service account do Firebase (FIREBASE_SERVICE_ACCOUNT_JSON).
# É necessário habilitar a Indexing API e a Search Console API no projeto e
# dar acesso de Proprietário à service account dentro do Search Console.

# --- Firebase Auth (login do usuário admin, igual ao painel) ---
# Web API Key do projeto: Console Firebase > Configurações do projeto > Geral > SDK do Firebase para a Web
FIREBASE_WEB_API_KEY=
FIREBASE_ADMIN_EMAIL=
FIREBASE_ADMIN_PASSWORD=

# --- Firebase Admin (upload da imagem de capa no Storage) ---
# JSON da service account em uma linha só (Console Firebase > Configurações do projeto > Contas de serviço > Gerar nova chave privada)
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_STORAGE_BUCKET=

# --- Geração de imagem de capa ---
# Provider usado para gerar a imagem de capa. Implementado: "openai".
IMAGE_GEN_PROVIDER=openai
IMAGE_GEN_API_KEY=

# --- Painel (fonte dos dados de acompanhamento) ---
# "local": lê os arquivos de estado do disco (rode local após git pull).
# "github": busca os arquivos de estado via API do GitHub (painel hospedado
# sempre online, que não recebe os commits da Action diretamente).
DATA_SOURCE=local
GITHUB_REPO=cleberfarias/NextAssist-blog-Automation
GITHUB_BRANCH=main
# Token de leitura (contents:read). OBRIGATÓRIO se o repositório for privado.
# Gere um fine-grained PAT com permissão "Contents: Read-only" só neste repo.
PANEL_GITHUB_TOKEN=
